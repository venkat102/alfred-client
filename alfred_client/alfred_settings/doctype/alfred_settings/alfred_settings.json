	"fields": [
		{
			"fieldname": "connection_tab",
			"fieldtype": "Tab Break",
			"label": "Connection"
		},
		{
			"fieldname": "connection_section",
			"fieldtype": "Section Break",
			"label": "Processing App Connection"
		},
		{
			"fieldname": "processing_app_url",
			"fieldtype": "Data",
			"label": "Processing App URL",
			"description": "WebSocket URL of the Alfred Processing App (e.g., wss://alfred-processing.example.com)"
		},
		{
			"fieldname": "api_key",
			"fieldtype": "Password",
			"label": "API Key",
			"description": "Authentication key for the Processing App. Stored encrypted."
		},
		{
			"fieldname": "column_break_conn",
			"fieldtype": "Column Break"
		},
		{
			"default": "0",
			"fieldname": "self_hosted_mode",
			"fieldtype": "Check",
			"label": "Self-Hosted Mode",
			"description": "Enable when running your own Processing App instance"
		},
		{
			"depends_on": "eval:doc.self_hosted_mode == 1",
			"fieldname": "redis_url",
			"fieldtype": "Data",
			"label": "Redis URL",
			"description": "Redis connection URL for self-hosted mode (e.g., redis://localhost:6379)"
		},
		{
			"fieldname": "llm_tab",
			"fieldtype": "Tab Break",
			"label": "LLM Configuration"
		},
		{
			"fieldname": "llm_configuration_section",
			"fieldtype": "Section Break",
			"label": "LLM Provider Settings"
		},
		{
			"fieldname": "llm_provider",
			"fieldtype": "Select",
			"label": "LLM Provider",
			"options": "\nollama\nanthropic\nopenai\ngemini\nbedrock",
			"description": "Select your LLM provider. Ollama for local models, others require API keys."
		},
		{
			"fieldname": "llm_model",
			"fieldtype": "Data",
			"label": "LLM Model",
			"description": "Model identifier (e.g., ollama/llama3.1, claude-sonnet-4-20250514, gpt-4o)"
		},
		{
			"depends_on": "eval:doc.llm_provider && doc.llm_provider !== 'ollama'",
			"fieldname": "llm_api_key",
			"fieldtype": "Password",
			"label": "LLM API Key",
			"description": "API key for the selected LLM provider. Not required for Ollama."
		},
		{
			"fieldname": "column_break_llm",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "llm_base_url",
			"fieldtype": "Data",
			"label": "LLM Base URL",
			"description": "Custom endpoint URL (e.g., http://localhost:11434 for Ollama). Leave empty for cloud providers."
		},
		{
			"default": "4096",
			"fieldname": "llm_max_tokens",
			"fieldtype": "Int",
			"label": "Max Tokens",
			"description": "Maximum tokens per LLM response"
		},
		{
			"default": "0.1",
			"fieldname": "llm_temperature",
			"fieldtype": "Float",
			"label": "Temperature",
			"description": "Generation temperature (0.0 = deterministic, 1.0 = creative). Recommended: 0.1 for code generation."
		},
		{
			"fieldname": "access_control_tab",
			"fieldtype": "Tab Break",
			"label": "Access Control"
		},
