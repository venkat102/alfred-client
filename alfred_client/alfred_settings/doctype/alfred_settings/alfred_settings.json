			"fieldname": "limits_tab",
			"fieldtype": "Tab Break",
			"label": "Limits"
		},
		{
			"fieldname": "limits_section",
			"fieldtype": "Section Break",
			"label": "Rate Limits & Timeouts"
		},
		{
			"default": "3",
			"fieldname": "max_retries_per_agent",
			"fieldtype": "Int",
			"label": "Max Retries Per Agent",
			"description": "Maximum retry loops before escalation to human"
		},
